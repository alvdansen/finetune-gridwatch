{# Shared cell / header markup — the SINGLE SOURCE of a grid cell's HTML.

   RUN-04 anti-drift: both the full-page render (grid.html.j2 loop) and the live
   layer's per-cell patch (render_cell_fragment) draw from these macros, so a
   patched cell can never structurally diverge from a full render. Every dynamic
   value stays inside autoescaped `{{ }}` — never marked `safe`, never
   f-string-built — so a prompt/step/filename escapes identically on both paths
   (T-4-02). The header macros (col_header / row_header) are the `header_html`
   source the live insert_row / insert_col patches broadcast (04-03). #}

{% macro cell(item, row_i, c_i, step, prompt, url, POPULATED, MISSING, BROKEN) -%}
        {% if item.cell.state == POPULATED %}
          {% if item.cell.sample.media_type == "video" %}
      {# Video cell (MEDIA-01): a DIV, NOT an anchor — full-cell click is
         play/pause in Plan 02. The <video> carries NO eager src; the client
         attaches `data-src` on first play. The poster is the clip's OWN first
         frame via the `#t=0.001` media fragment (no ffmpeg / no generated
         thumbnails, D-10). `#t=0.001` is a STATIC in-template literal — never
         user data (Pitfall 5); every dynamic value stays autoescaped in {{ }}. #}
      <div class="cell cell--video{% if item.cell.ar_mismatch %} cell--mismatch{% endif %}"
           data-r="{{ row_i }}" data-c="{{ c_i }}"
           data-video data-src="{{ url(item.cell.sample) }}#t=0.001"
           role="button" tabindex="0" aria-pressed="false"
           aria-label="Play/pause — step {{ step }}, {{ prompt }}"
           title="step {{ step }} · {{ prompt }}">
        <video muted playsinline loop preload="none" aria-hidden="true"></video>
        <span class="cell__play" aria-hidden="true">▶</span>
        {# Pop-out (D-05): opens the RAW clip in a new tab using the CLEAN url
           (NO `#t=` poster fragment). rel=noopener noreferrer blocks reverse
           tabnabbing on the new tab (T-3-03), identical to the image anchor. #}
        <a class="cell__popout" href="{{ url(item.cell.sample) }}"
           target="_blank" rel="noopener noreferrer"
           aria-label="Open clip in new tab">⧉</a>
        {% if item.cell.has_alternates %}
        <span class="cell__alt-badge"
              title="Alternate seeds: {{ item.cell.alternate_seeds | join(', ') }}">alt</span>
        {% endif %}
      </div>
          {% else %}
      <a class="cell{% if item.cell.ar_mismatch %} cell--mismatch{% endif %}"
         data-r="{{ row_i }}" data-c="{{ c_i }}"
         href="{{ url(item.cell.sample) }}" target="_blank" rel="noopener noreferrer"
         title="step {{ step }} · {{ prompt }}">
        <img src="{{ url(item.cell.sample) }}" alt="step {{ step }}, {{ prompt }}"
             loading="lazy" decoding="async">
        {# Duplicate-seed alternate badge (D-10/D-09): only on cells where >1
           sample collided at this coordinate. Every seed value is interpolated
           through autoescaped {{ }} — never string-concatenated in Python. #}
        {% if item.cell.has_alternates %}
        <span class="cell__alt-badge"
              title="Alternate seeds: {{ item.cell.alternate_seeds | join(', ') }}">alt</span>
        {% endif %}
      </a>
          {% endif %}
        {% elif item.cell.state == BROKEN %}
      {# Broken: file present but won't decode — amber, solid, ⚠ (D-10). Not clickable. #}
      <div class="cell cell--broken" data-r="{{ row_i }}" data-c="{{ c_i }}"
           title="File found but couldn't be displayed — {{ item.cell.sample.path.name }}">
        <span class="cell__glyph" aria-hidden="true">⚠</span>
        <span class="cell__caption">Can't render</span>
      </div>
        {% else %}
      {# Missing: nothing was ever here — cold, dashed, em dash (D-09). Not clickable. #}
      <div class="cell cell--missing" data-r="{{ row_i }}" data-c="{{ c_i }}"
           title="No sample for step {{ step }} · {{ prompt }}">
        <span class="cell__glyph" aria-hidden="true">—</span>
        <span class="cell__caption">s{{ step }}·{{ prompt }}</span>
      </div>
        {% endif %}
{%- endmacro %}


{% macro col_header(prompt, c_i) -%}
      <div class="col-header" role="columnheader" data-c="{{ c_i }}" title="{{ prompt }}" aria-label="{{ prompt }}">{{ prompt }}</div>
{%- endmacro %}


{% macro row_header(step, row_i) -%}
      <div class="row-header" role="rowheader" data-r="{{ row_i }}">{{ step }}</div>
{%- endmacro %}
