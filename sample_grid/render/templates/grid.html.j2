{% import "cell.j2" as c -%}
<!DOCTYPE html>
<html lang="en" data-theme="dark" data-density="comfortable" data-sync="independent">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Sample Grid — steps × prompts</title>
  {# css is a STATIC, trusted asset read from disk — emit it verbatim. Marking
     it `safe` is NOT a T-1-01 regression: it carries no user data, and inside a
     <style> block the browser does not decode HTML entities, so autoescaping the
     font-family quotes (&#34;) would actually BREAK the CSS. All dynamic
     prompt/filename interpolation below stays autoescaped. #}
  <style>
{{ css | safe }}
/* Build-injected (override the CSS defaults): detected AR (D-11), the CLI cell
   size (D-08), and the prompt-column count for the grid template. */
:root {
  --cell-ar: {{ cell_ar_css }};
  --cell-size: {{ cell_size_px }}px;
  --n-cols: {{ n_cols }};
}
  </style>
</head>
<body>
  {# Pinned theme/density toggle (D-03). Buttons carry data-set="key:value" +
     aria-pressed; grid.js (inlined near </body>) wires them and persists the
     choice to localStorage. With JS disabled the page keeps the dark/comfortable
     defaults baked into the CSS :root — the toggle simply does nothing. #}
  <div class="toggle-bar">
    <div class="toggle-group" role="group" aria-label="Theme">
      <span class="toggle-label">Theme</span>
      <button type="button" class="toggle-seg" data-set="theme:dark" aria-pressed="true">Dark</button>
      <button type="button" class="toggle-seg" data-set="theme:light" aria-pressed="false">Light</button>
    </div>
    <div class="toggle-group" role="group" aria-label="Density">
      <span class="toggle-label">Density</span>
      <button type="button" class="toggle-seg" data-set="density:comfortable" aria-pressed="true">Comfortable</button>
      <button type="button" class="toggle-seg" data-set="density:compact" aria-pressed="false">Compact</button>
    </div>
    {# Sync toggle (D-06 / MEDIA-03): same data-set="key:value" + aria-pressed
       shape as theme/density; grid.js reuses the identical [data-set] loop and
       persists to localStorage. Default is Independent (baked into <html
       data-sync="independent">) so the grid stays low-friction until the user
       opts into frame-locked comparison. #}
    <div class="toggle-group" role="group" aria-label="Sync">
      <span class="toggle-label">Sync</span>
      <button type="button" class="toggle-seg" data-set="sync:independent" aria-pressed="true">Independent</button>
      <button type="button" class="toggle-seg" data-set="sync:synced" aria-pressed="false">Synced</button>
    </div>
    {# D-07 visual-obviousness: a persistent SYNCED badge that CSS reveals ONLY
       while data-sync="synced" (paired with the accent border on this bar), so a
       2+ cell comparison is never silently out-of-phase. Static literal — no
       user data, nothing to escape. #}
    <span class="sync-badge" aria-hidden="true">SYNCED</span>
    {# Global playback controls (MEDIA-04 / D-09). These are plain ACTION buttons
       (NOT data-set toggles): a PROMINENT Pause-all calms the whole grid back to
       frozen comparison frames (in Synced mode all snap to the exact master
       frame), and a SECONDARY Play-visible starts ONLY the cells currently in
       the viewport, honoring the concurrent-play cap — never a whole-grid
       play-everything control (D-09 calm default). grid.js wires these by id.
       Static literals — no user data, nothing to escape. #}
    <div class="toggle-group" role="group" aria-label="Playback">
      <button type="button" class="control-btn control-btn--primary" id="pause-all">Pause all</button>
      <button type="button" class="control-btn" id="play-visible">Play visible</button>
    </div>
  </div>

  {# In-page seed-variance marker (D-09). Fired by build_grid's `seed_varies`,
     which ORs the per-coordinate multi-seed case AND the cross-cell seed
     confound — so this banner appears in the frozen HTML whenever seeds are
     mixed, keeping a terminal-free viewer honest. It carries no dynamic data,
     so there is nothing to escape here; any per-cell seed value below goes
     through autoescaped {{ }}. #}
  {% if seed_varies %}
  <div class="seed-variance" role="status" data-seed-variance>
    <span class="seed-variance__glyph" aria-hidden="true">⚠</span>
    <span class="seed-variance__text">Seeds vary across this grid — samples are not seed-locked.</span>
  </div>
  {% endif %}

  <div class="grid-scroll">
    <div class="grid" role="grid" aria-label="Model samples — steps as rows, prompts as columns">
      {# Corner cell + column (prompt) headers — sticky top #}
      <div class="corner" role="columnheader">step ╲ prompt</div>
      {% for prompt in prompts %}
      {{ c.col_header(prompt, loop.index0) }}
      {% endfor %}

      {# One dense row per step; row-header (left, sticky) then a cell per prompt.
         data-r / data-c carry the (row, col) coordinate so grid.js can light the
         shared row + column on hover/focus (crosshair scan aid). #}
      {% for row in rows %}
      {% set row_i = loop.index0 %}
      {{ c.row_header(row.step, row_i) }}
      {% for item in row.cells %}{{ c.cell(item, row_i, loop.index0, row.step, item.prompt, url, POPULATED, MISSING, BROKEN) }}{% endfor %}
      {% endfor %}
    </div>
  </div>

  {# Live gate (RUN-02): only when SERVING live does the page carry the
     LIVE_ENDPOINT constant the client's EventSource wiring keys on. On the
     frozen/build path (live=False) NOTHING is injected, so the artifact stays
     file://-safe with no server surface (locked by
     test_toggle_js_inlined_offline_safe / test_live_flag_gates_eventsource).
     The endpoint literal is a STATIC in-template value — no user data. #}
  {% if live %}<script>window.LIVE_ENDPOINT = "/events";</script>{% endif %}
  {# Inlined client JS (static, trusted) — marked `safe` for the same reason as
     css above: inside a <script> block the browser does not decode entities, so
     autoescaping its `>` / `"` would break the script. It is vanilla and
     file://-safe — NO EventSource / no server wiring (live=False in P1). #}
  <script>
{{ js | safe }}
  </script>
</body>
</html>
